{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "STM32: Debug active CMake target",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "servertype": "stlink",
      "device": "${config:stm32.device}",
      "interface": "${config:stm32.interface}",
      "gdbPath": "${config:stm32.toolchainGdbPath}",
      "stlinkPath": "${config:stm32.stlinkGdbServerPath}",
      "stm32cubeprogrammer": "${config:stm32.cubeProgrammerPath}",
      "runToEntryPoint": "${config:stm32.runToEntryPoint}",
      "executable": "${workspaceFolder}/build/Debug/${config:stm32.projectName}.elf",
      "preLaunchTask": "STM32: Build"
    },
    {
      "name": "STM32: Debug via external GDB Server",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "servertype": "external",
      "gdbTarget": "localhost:61234",
      "device": "${config:stm32.device}",
      "interface": "${config:stm32.interface}",
      "gdbPath": "${config:stm32.toolchainGdbPath}",
      "runToEntryPoint": "${config:stm32.runToEntryPoint}",
      "executable": "${workspaceFolder}/build/Debug/${config:stm32.projectName}.elf",
      "overrideLaunchCommands": [
        "monitor halt",
        "load",
        "monitor reset",
        "monitor halt"
      ],
      "overrideResetCommands": [
        "monitor reset",
        "monitor halt"
      ],
      "preLaunchTask": "STM32: Start GDB Server",
      "postDebugTask": "STM32: Stop GDB Server"
    },
    {
      "name": "STM32: Attach active CMake target",
      "type": "cortex-debug",
      "request": "attach",
      "cwd": "${workspaceFolder}",
      "servertype": "stlink",
      "device": "${config:stm32.device}",
      "interface": "${config:stm32.interface}",
      "gdbPath": "${config:stm32.toolchainGdbPath}",
      "stlinkPath": "${config:stm32.stlinkGdbServerPath}",
      "stm32cubeprogrammer": "${config:stm32.cubeProgrammerPath}",
      "executable": "${workspaceFolder}/build/Debug/${config:stm32.projectName}.elf"
    }
  ]
}
